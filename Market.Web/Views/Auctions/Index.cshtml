@model Market.Web.Core.ViewModels.AuctionListViewModel
@{
    ViewData["Title"] = "Aukcje";
    
}

<link rel="stylesheet" href="~/css/auction-index.css" asp-append-version="true" />
<h1>Aktualne Aukcje</h1>

<p>
    <a asp-action="Create" class="btn btn-success">+ Dodaj Nową</a>
</p>

<!-- Sekcja Filtrowania i Wyszukiwania -->
<form asp-controller="Auctions" asp-action="Index" method="get" class="mb-5 p-3 rounded shadow-sm" id="search-form">
    <div class="row g-3">
        
        <!-- Wyszukiwarka -->
        <div class="col-md-12">
            <div class="input-group">
                  <input type="text" id="search-input" name="searchString" class="form-control" 
                       placeholder="Szukaj po tytule lub opisie..."
                       value="@Model.SearchString" />
                <button type="submit" class="btn btn-primary">Szukaj</button>
            </div>
        </div>

        <!-- Filtr Kategorii -->
        <div class="col-md-3">
            <label class="form-label fw-bold">Kategoria</label>
            <select name="category" class="form-select">
                <option value="" selected="@(Model.Category == null)">-- Wszystkie --</option>
                <option value="Elektronika" selected="@(Model.Category == "Elektronika")">Elektronika</option>
                <option value="Moda" selected="@(Model.Category == "Moda")">Moda</option>
                <option value="Dom i Ogród" selected="@(Model.Category == "Dom i Ogród")">Dom i Ogród</option>
                <option value="Sport i Hobby" selected="@(Model.Category == "Sport i Hobby")">Sport i Hobby</option>
                <option value="Motoryzacja" selected="@(Model.Category == "Motoryzacja")">Motoryzacja</option>
                <option value="Kultura i Rozrywka" selected="@(Model.Category == "Kultura i Rozrywka")">Kultura i Rozrywka</option>
                <option value="Inne" selected="@(Model.Category == "Inne")">Inne</option>
            </select>
        </div>

        <!-- Filtr Ceny -->
        <div class="col-md-5">
            <label class="form-label fw-bold">Cena (PLN)</label>
            <div class="input-group">
                <input type="number" name="minPrice" class="form-control"
                       placeholder="Od" step="0.01"
                       value="@Model.MinPrice" />
                <span class="input-group-text">-</span>
                <input type="number" name="maxPrice" class="form-control"
                       placeholder="Do" step="0.01"
                       value="@Model.MaxPrice" />
            </div>
        </div>

        <!-- Sortowanie -->
        <div class="col-md-4">
            <label class="form-label fw-bold">Sortowanie i Akcje</label>
            <div class="btn-group w-100" role="group">
                <button type="submit" name="sortOrder" value="price_asc" class="btn btn-secondary">
                    Cena &uarr;
                </button>
                <button type="submit" name="sortOrder" value="price_desc" class="btn btn-secondary">
                    Cena &darr;
                </button>
                <a asp-action="Index" class="btn btn-danger">Wyczyść</a>
            </div>
        </div>
    </div> 
</form>

<div id="auction-results">
    <partial name="_AuctionListPartial" model="Model" />
</div>


@section Scripts {
    <script src="~/js/search.js" asp-append-version="true"></script>
}
